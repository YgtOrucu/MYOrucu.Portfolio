@model UpdateExperienceDto
@{
    Layout = "~/Views/Shared/_MYOrucuAdminLayout.cshtml";
    ViewData["Title"] = "Deneyim Güncelle";
    ViewData["AdminSection"] = "Deneyimler";
}

<nav class="eu-breadcrumb" aria-label="breadcrumb">
    <a href="/AdminExperience/ExperienceList"><i class="bi bi-briefcase-fill"></i> Deneyimler</a>
    <i class="bi bi-chevron-right bc-sep"></i>
    <span>Güncelle &mdash; #@Model.ExperienceId</span>
</nav>

<div class="eu-header">
    <h1 class="eu-title">Deneyimi Güncelle</h1>
    <p class="eu-subtitle">// experience/update &mdash; mevcut kaydı düzenle</p>
</div>
<div asp-validation-summary="ModelOnly" class="validation-summary">
    <div class="d-flex align-items-center mb-2">
        <i class="fa-solid fa-circle-exclamation me-2"></i>
        <span><strong>Lütfen aşağıdaki hataları düzeltin:</strong></span>
    </div>
</div>
<form method="post" action="/AdminExperience/ExperienceUpdate">
    @Html.AntiForgeryToken()
    <input type="hidden" name="ExperienceId" value="@Model.ExperienceId" />

    <div class="eu-card">
        <div class="eu-card-header">
            <div class="eu-card-icon"><i class="bi bi-building"></i></div>
            <span class="eu-card-title">// Temel Bilgiler</span>
            <span class="eu-id-chip">ID: @Model.ExperienceId</span>
        </div>
        <div class="eu-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="eu-field">
                        <label class="eu-label" for="Company">Şirket Adı</label>
                        <input type="text" class="eu-input" id="Company" name="Company"
                               value="@Model.Company" placeholder="TechCorp A.Ş." required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="eu-field">
                        <label class="eu-label" for="Title">Pozisyon / Unvan</label>
                        <input type="text" class="eu-input" id="Title" name="Title"
                               value="@Model.Title" placeholder="Senior .NET Developer" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="eu-field">
                        <label class="eu-label" for="Date">Tarih Aralığı</label>
                        <input type="text" class="eu-input" id="Date" name="Date"
                               value="@Model.Date" placeholder="Mar 2022 — Günümüz" />
                        <span class="eu-hint">Serbest metin — örn: "Oca 2020 — Mar 2022"</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="eu-field">
                        <label class="eu-label" for="WorkMethod">Çalışma Şekli</label>
                        <input type="text" class="eu-input" id="WorkMethod" name="WorkMethod"
                               value="@Model.WorkMethod" placeholder="Ofis / Uzaktan / Hibrit" required />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="eu-card">
        <div class="eu-card-header">
            <div class="eu-card-icon"><i class="bi bi-card-text"></i></div>
            <span class="eu-card-title">// Açıklama &amp; Başarılar</span>
        </div>
        <div class="eu-card-body">
            <span class="eu-hint" style="display:block;margin-bottom:.8rem;">
                Her madde ayrı bir başarı veya sorumluluk satırı olarak gösterilecek.
            </span>
            <div class="dyn-list" id="descriptionList">
                @if (Model.Description != null)
                {
                    for (int i = 0; i < Model.Description.Count; i++)
                    {
                        <div class="dyn-row">
                            <textarea class="eu-input eu-textarea" rows="2"
                                      name="Description[@i]"
                                      placeholder="Başarı veya sorumluluk...">@Model.Description[i]</textarea>
                            <button type="button" class="btn-dyn-remove" title="Kaldır">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    }
                }
            </div>
            <button type="button" class="btn-dyn-add" id="addDescription">
                <i class="bi bi-plus-lg"></i> Yeni Madde Ekle
            </button>
        </div>
    </div>

    <div class="eu-card">
        <div class="eu-card-header">
            <div class="eu-card-icon"><i class="bi bi-tags"></i></div>
            <span class="eu-card-title">// Kullanılan Teknolojiler</span>
        </div>
        <div class="eu-card-body">
            <span class="eu-hint" style="display:block;margin-bottom:.8rem;">
                Her alan bir teknoloji etiketi olarak kart üzerinde görünecek.
            </span>
            <div class="dyn-list" id="techList">
                @if (Model.UseTechnology != null)
                {
                    for (int i = 0; i < Model.UseTechnology.Count; i++)
                    {
                        <div class="dyn-row">
                            <input type="text" class="eu-input"
                                   name="UseTechnology[@i]"
                                   value="@Model.UseTechnology[i]"
                                   placeholder=".NET 8 / Azure / Redis ..." />
                            <button type="button" class="btn-dyn-remove" title="Kaldır">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    }
                }
            </div>
            <button type="button" class="btn-dyn-add" id="addTech">
                <i class="bi bi-plus-lg"></i> Teknoloji Ekle
            </button>
        </div>
    </div>

    <div class="eu-card">
        <div class="eu-card-body">
            <div class="eu-form-actions">
                <button type="submit" class="btn-update">
                    <i class="bi bi-arrow-repeat"></i> Güncelle
                </button>
                <a href="/AdminExperience/ExperienceList" class="btn-cancel">
                    <i class="bi bi-x-lg"></i> Vazgeç
                </a>
            </div>
        </div>
    </div>

</form>