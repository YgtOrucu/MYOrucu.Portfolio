@model GetForFooterSection
<footer>
    <div class="container">
        <div class="row align-items-center gy-3">
            <div class="col-md-6">
                <div class="footer-brand">@Model.BrandInitials.</div>
                <div class="footer-copy">© @DateTime.Now.Year @Model.FullName. Tüm hakları saklıdır.</div>
                <div class="footer-built">Designed &amp; Built by <span>@Model.FullName</span></div>
            </div>
            <div class="col-md-6">
                <div class="footer-social">
                    <a href="@Model.GithubUrl" target="_blank" rel="noopener" class="social-link"><i class="bi bi-github"></i></a>
                    <a href="@Model.LinkedinUrl" target="_blank" rel="noopener" class="social-link"><i class="bi bi-linkedin"></i></a>
                    <a href="mailto:@Model.EmailAddress" class="social-link"><i class="bi bi-envelope"></i></a>
                </div>
            </div>
        </div>
    </div>
</footer>